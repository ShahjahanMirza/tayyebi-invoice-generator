{
  "name": "tayyebi-invoicing",
  "version": "1.1.0",
  "description": "Tayyebi Dawakhana Invoicing System",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "dist": "vite build && electron-builder --publish always",
    "preview": "electron ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.42.0",
    "electron-updater": "^6.8.3",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "pk.tayyebi.invoicing",
    "productName": "Tayyebi Invoicing",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "pdfGenerator.js",
      "logo.png",
      "node_modules/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "perMachine": false
    },
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "ShahjahanMirza",
      "repo": "tayyebi-invoice-generator"
    },
    "extraResources": [
      {
        "from": "tayyebi_app_data/Data",
        "to": "initialData",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
